---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Mori Matcha Club | Brand Showcase',
	description = 'A purposeful matcha brand showcase for Mori Matcha Club.'
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700;800&family=MuseoModerno:wght@500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/png" href="/morimatchalogo-white.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
